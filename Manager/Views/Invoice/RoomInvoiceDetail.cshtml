@model Manager.Models.RoomInvoice

<div class="container-fluid position-relative d-flex p-0">
    <div class="col m-5">
        <div class="card bg-light rounded h-100 p-4">
            <form asp-action="StudentDetail" asp-controller="User">
                <div class="row g-5">
                    <div class="col-md-12 col-lg-6 col-xl-4">
                        <div class="form-item">
                            <label class="form-label my-3 fw-bold">Mã hóa đơn</label>
                            <input class="form-control" value="@Model.InvoiceID">
                        </div>
                    </div>
                    <div class="col-md-12 col-lg-6 col-xl-4">
                        <div class="form-item">
                            <label class="form-label my-3 fw-bold">Phòng</label>
                            <input class="form-control" value="@Model.RoomName">
                        </div>
                    </div>
                    <div class="col-md-12 col-lg-6 col-xl-4">
                        <div class="form-item">
                            <label class="form-label my-3 fw-bold">Tòa nhà</label>
                            <input class="form-control" value="@Model.BuildingName">
                        </div>
                    </div>
                </div>
                <div class="row g-5">
                    <div class="col-md-12 col-lg-6 col-xl-4">
                        <div class="form-item">
                            <label class="form-label my-3 fw-bold">Người thanh toán</label>
                            <input class="form-control" value="@Model.PayerName">
                        </div>
                    </div>
                    <div class="col-md-12 col-lg-6 col-xl-4">
                        <div class="form-item">
                            <label class="form-label my-3 fw-bold">Ngày thanh toán</label>
                            <input type="date" class="form-control" value="@Model.PaymentDate?.ToString("yyyy-MM-dd")">
                        </div>
                    </div>
                    <div class="col-md-12 col-lg-6 col-xl-4">
                        <div class="form-item">
                            <label class="form-label my-3 fw-bold">Ngày lập hóa đơn</label>
                            <input type="date" class="form-control" value="@Model.IssueDate?.ToString("yyyy-MM-dd")">
                        </div>
                    </div>
                </div>
                <div class="row g-5">
                    <div class="col-md-12 col-lg-6 col-xl-4">
                        <div class="form-item">
                            <label class="form-label my-3 fw-bold">Mô tả</label>
                            <input class="form-control" value="@Model.Description">
                        </div>
                    </div>
                    <div class="col-md-12 col-lg-6 col-xl-4">
                        <div class="form-item">
                            <label class="form-label my-3 fw-bold">Ghi chú</label>
                            <input class="form-control" value="@Model.Note">
                        </div>
                    </div>
                    <div class="col-md-12 col-lg-6 col-xl-4">
                        <div class="form-item">
                            <label class="form-label my-3 fw-bold">Tình trạng</label>
                            <input class="form-control" value="@Model.Status">
                        </div>
                    </div>
                </div>
                <div class="row g-5 w-75">
                    <p class="fw-bold p-4">Các dịch vụ sử dụng</p>
                    <table class="table table-striped m-3">
                        <thead class="fw-bold">
                            <tr>
                                <th scope="col">STT</th>
                                <th scope="col">Tên dịch vụ</th>
                                <th scope="col">Số lượng sử dụng</th>
                                <th scope="col">Đơn vị tính</th>
                                <th scope="col">Đơn giá</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>1</td>
                                <td>Điện</td>
                                <td>50</td>
                                <td>kWh</td>
                                <td>3000</td>
                            </tr>

                            <tr><td>2</td>
                                <td>Nước</td>
                                <td>50</td>
                                <td>m3</td>
                                <td>40000</td>
                            </tr>
                        </tbody>
                    </table>
                    <p class="fw-bold p-4">Tổng tiền: @Model.TotalAmount</p>
                </div>
                <div class="row m-5">
                    <div class="col-4"></div>
                    <div class="col-2">
                        <a asp-controller="Invoice" asp-action="QR" asp-for="@Model.InvoiceID" class="btn btn-success m-2">Thanh toán </a>
                    </div>
                    <div class="col-2">
                        
                    </div>
                    <div class="col-4"></div>
                </div>
            </form>
        </div>
    </div>
</div>
